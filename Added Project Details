elif shape == "triangle": 
for i in range(1, n + 1): 
print("* " * i) 
elif shape == "pyramid": 
for i in range(1, n + 1): 
print(" " * (n - i) + "* " * i) 
elif shape == "circle": 
r = n 
for i in range(-r, r + 1): 
for j in range(-r, r + 1): 
if i*i + j*j <= r*r: 
print("*", end=" ") 
